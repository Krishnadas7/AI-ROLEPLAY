# ==============================================================
#         AI ROLEPLAY — ROOT ENVIRONMENT EXAMPLE
# ==============================================================
# Copy this file to .env and fill in your actual values.
# Each sub-folder (frontend/, backend/) also has its own .env.
# ==============================================================

# --------------------------------------------------------------
# PROJECT DETAILS
# --------------------------------------------------------------
PROJECT_NAME=AI-ROLEPLAY
PROJECT_VERSION=1.0.0
PROJECT_DESCRIPTION=

# --------------------------------------------------------------
# DEPLOYMENT URLS
# --------------------------------------------------------------
FRONTEND_URL=
BACKEND_URL=
LOCAL_FRONTEND_URL=http://localhost:5173
LOCAL_BACKEND_URL=http://localhost:3000

# --------------------------------------------------------------
# ENVIRONMENT  (development | production)
# --------------------------------------------------------------
NODE_ENV=development

# ==============================================================
#  BACKEND ENV  →  Also set inside /backend/.env
# ==============================================================
# PORT=3000
# DB=
# DB1=
# CLAUDE_API_KEY=
# AI_MODEL=claude-3-haiku-20240307

# ==============================================================
#  FRONTEND ENV  →  Also set inside /frontend/.env
# ==============================================================
# VITE_APP_BASE_URL=http://localhost:3000/api/v1
