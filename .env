# ==============================================================
#              AI ROLEPLAY — ROOT ENVIRONMENT CONFIG
# ==============================================================
# This file provides a high-level overview of the project's
# environment configuration. Each sub-application maintains
# its own .env file inside its respective folder.
#
# PROJECT STRUCTURE:
#   AI-ROLEPLAY/
#   ├── .env                  ← You are here (root overview)
#   ├── frontend/
#   │   └── .env              ← Frontend-specific env (Vite)
#   └── backend/
#       └── .env              ← Backend-specific env (Node/Express)
# ==============================================================

# --------------------------------------------------------------
# PROJECT DETAILS
# --------------------------------------------------------------
PROJECT_NAME=AI-ROLEPLAY
PROJECT_VERSION=1.0.0
PROJECT_DESCRIPTION="AI-powered roleplay training platform for telecom support scenarios"

# --------------------------------------------------------------
# DEPLOYMENT URLS
# --------------------------------------------------------------
# Live frontend (Vercel / Render)
FRONTEND_URL=https://ai-roleplay-1.onrender.com

# Live backend API (Render)
BACKEND_URL=https://ai-roleplay-api.onrender.com

# Local development
LOCAL_FRONTEND_URL=http://localhost:5173
LOCAL_BACKEND_URL=http://localhost:3000

# --------------------------------------------------------------
# ENVIRONMENT
# --------------------------------------------------------------
# Set to: development | production
NODE_ENV=development

# ==============================================================
#  BACKEND ENV  →  See /backend/.env for actual values
# ==============================================================
# PORT=3000
# DB=<mongodb_atlas_connection_string>
# DB1=<mongodb_local_connection_string>
# CLAUDE_API_KEY=<your_anthropic_api_key>
# AI_MODEL=claude-3-haiku-20240307

# ==============================================================
#  FRONTEND ENV  →  See /frontend/.env for actual values
# ==============================================================
# VITE_APP_BASE_URL=http://localhost:3000/api/v1

# ==============================================================
# NOTE: Never commit actual .env files with real secrets to Git.
#       Use .env.example files as safe, blank templates.
# ==============================================================
